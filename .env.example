# Offline AI Chat — environment template
# Copy this file to `.env` and adjust values. The Node server reads these on
# startup via process.env (no dotenv loader — pass them through your shell or
# Docker Compose `environment:` block).

# ─── HTTP server ────────────────────────────────────────────────────────────
# Native Node default seguro: localhost apenas.
# Para publicar em LAN, use HOST=0.0.0.0 e configure auth + whitelists abaixo.
HOST=127.0.0.1
PORT=8080

# Autenticacao nativa opcional via HTTP Basic Auth.
# Recomendado/obrigatorio na pratica para LAN.
APP_AUTH_USER=offline-ai
# APP_AUTH_PASSWORD=troque-esta-senha
# Alternativa: APP_AUTH_TOKEN=token-longo-aleatorio

# Hosts LM Studio que o proxy pode acessar.
# Vazio em modo local permite qualquer baseUrl. Quando HOST expõe LAN,
# vazio permite apenas loopback (localhost/127.x/::1).
# Exemplos:
# ALLOWED_LM_HOSTS=localhost,127.0.0.1:1234,host.docker.internal:1234,192.168.1.50:1234,lmstudio.intra:1234

# ─── Workspace (filesystem source for RAG) ─────────────────────────────────
# CSV of absolute paths the server is allowed to read for /api/fs/*.
# Empty em HOST local = single-user mode: qualquer pasta conectada via UI e aceita.
# Empty em HOST=0.0.0.0 = endpoints de filesystem ficam bloqueados por seguranca.
# Path traversal protection is always on regardless of this setting.
# Example:
# WORKSPACE_ROOTS=/workspace,/host/c/Projects

# Override explicito para permitir qualquer sourceRoot mesmo em LAN.
# Use apenas em maquina single-user atras de firewall/VPN confiavel.
# ALLOW_UNRESTRICTED_WORKSPACE=false

# ─── OCR (tesseract.js) ────────────────────────────────────────────────────
# Languages used when OCR is enabled (Settings → Workspace → "OCR para PDFs
# escaneados"). Plus-separated. Models are auto-downloaded from CDN on first
# use and cached locally; mounting the cache directory as a Docker volume
# avoids re-downloading after restart.
OCR_LANGS=por+eng

# Where tesseract.js stores trained data files. Inside Docker the
# docker-compose volume `tesseract-cache` is mounted here.
OCR_CACHE_DIR=/app/.cache/tesseract

# ─── Optional limits (uncomment to override defaults) ───────────────────────
# Maximum file size for /api/fs/read* and uploads, in bytes.
# MAX_FILE_BYTES=2097152              # 2 MiB
# MAX_PDF_BYTES=33554432              # 32 MiB
# MAX_BODY_BYTES=46976205             # ~1.4x MAX_PDF_BYTES para upload PDF base64

# ─── Tarefas agendadas (cron engine) ───────────────────────────────────────
# Desligado por default (opt-in). A EXECUÇÃO só roda com CRON_ENABLED=true;
# o gerenciamento pela UI (Configurações → Tarefas) funciona sempre.
# CRON_ENABLED=true
#
# Whitelist SEPARADA de WORKSPACE_ROOTS — única(s) pasta(s) onde as tarefas
# podem ESCREVER (boletins, backups, rotação). Nunca aponte pro mount :ro de
# leitura. Vazio = escrita desabilitada (tarefas que escrevem falham).
# FS_WRITE_ROOTS=/app/data/output
#
# Onde fica o cron-state.json (definições de tarefas + conexões + histórico).
# CRON_STATE_DIR=/app/data
#
# Fuso horário IANA pros horários ("8h" etc). Vazio = UTC.
# CRON_TZ=America/Sao_Paulo
#
# Teto de timeout por tarefa (ms) e disjuntor de falhas consecutivas.
# CRON_MAX_TIMEOUT_MS=300000
# CRON_MAX_FAILURES=5
# MAX_WRITE_BYTES=5242880             # 5 MiB por arquivo escrito
#
# Seed opcional: JSON com estado inicial, aplicado SÓ na 1ª execução (se o
# state file ainda não existe). Depois a UI manda.
# CRON_SEED_FILE=/app/config/cron-seed.json
