# Copy to `.env.lan` or generate it with:
#   npm run lan:setup

# Where the web app is reachable from the LAN.
APP_BIND=0.0.0.0
APP_PORT=8080

# Browser login for the Offline AI Chat app.
APP_AUTH_USER=offline-ai
APP_AUTH_PASSWORD=change-this-long-password

# Host folder to expose as the read-only workspace inside the container.
# Windows example: C:/Users/pabst/Documents/company-rag
# Linux example: /srv/offline-ai/workspace
LAN_WORKSPACE_HOST_PATH=/srv/offline-ai/workspace

# LM Studio hosts/ports the proxy may talk to.
# Must match what users put in Settings -> Servidor.
ALLOWED_LM_HOSTS=192.168.1.50:1234

# Optional runtime knobs.
OCR_LANGS=por+eng
MAX_FILE_BYTES=262144
MAX_PDF_BYTES=33554432
