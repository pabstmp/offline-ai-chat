{
  "name": "offline-ai-chat",
  "version": "2.0.0",
  "description": "Self-hosted web client for LM Studio with offline RAG, OCR, multilingual embeddings, and zero client-side dependencies.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "check": "node scripts/check.js",
    "test": "node tests/feature-improvements.test.js && node tests/security-server.test.js && node tests/cron.test.js",
    "lan:setup": "node scripts/setup-lan.js",
    "lan:up": "docker compose --env-file .env.lan -f docker-compose.lan.yml up -d --build",
    "lan:down": "docker compose --env-file .env.lan -f docker-compose.lan.yml down",
    "lan:logs": "docker logs offline-ai-chat-lan --tail 80"
  },
  "keywords": [
    "lm-studio",
    "rag",
    "ocr",
    "tesseract",
    "embeddings",
    "offline-ai",
    "self-hosted",
    "vanilla-js",
    "chat-ui",
    "local-llm",
    "openai-compatible",
    "qwen3-embedding"
  ],
  "author": "pabstmp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pabstmp/offline-ai-chat.git"
  },
  "homepage": "https://github.com/pabstmp/offline-ai-chat#readme",
  "bugs": {
    "url": "https://github.com/pabstmp/offline-ai-chat/issues"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.56",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^5.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "fast-check": "^4.7.0"
  }
}
